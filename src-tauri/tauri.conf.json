{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenEcho",
  "version": "2.0.0",
  "identifier": "com.openecho.desktop",
  "build": {
    "beforeDevCommand": "node scripts/dev-tauri.mjs",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenEcho",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  }
}
