{
  "name": "openecho",
  "version": "2.0.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@mui/icons-material": "^5.11.0",
    "@mui/lab": "^5.0.0-alpha.114",
    "@mui/material": "^5.11.1",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "react": "^18.2.0",
    "react-backdrop-filter": "^2.1.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-window": "^1.8.8"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:frontend": "react-scripts start",
    "start:backend": "python main.py --reload --port 8420",
    "build": "react-scripts build",
    "build:backend-binary": "node scripts/run_python_sidecar_build.mjs",
    "build:tauri": "npm run build && npm run build:backend-binary",
    "release:dmg": "node scripts/build_dmg.mjs",
    "tauri:dev": "node scripts/run-tauri.mjs dev",
    "tauri:build": "node scripts/run-tauri.mjs build --ci --config src-tauri/tauri.bundle.conf.json",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
